<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <title>Aufgabe wählen | THW</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --bg-deep: #0f172a;
            --bg-card: #1e293b;
            --bg-input: #334155;
            --thw-blue: #2563eb;
            --thw-yellow: #fbbf24;
            --success: #10b981;
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --border: #334155;
            --radius: 16px;
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background-color: var(--bg-deep);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
            box-sizing: border-box;
        }

        .container {
            width: 100%;
            max-width: 500px;
        }

        .participant-card {
            background: var(--bg-card);
            padding: 24px;
            border-radius: var(--radius);
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            border: 1px solid var(--border);
            margin-bottom: 24px;
            text-align: center;
        }

        .avatar-circle {
            width: 50px;
            height: 50px;
            background: var(--thw-blue);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            font-weight: bold;
            margin: 0 auto 12px;
        }

        .participant-name {
            font-size: 1.3rem;
            font-weight: 700;
            margin: 0;
            color: var(--text-main);
        }

        .badge-info {
            display: inline-block;
            margin-top: 8px;
            padding: 4px 12px;
            background: rgba(251, 191, 36, 0.1);
            color: var(--thw-yellow);
            border: 1px solid rgba(251, 191, 36, 0.3);
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
        }

        h2 {
            font-size: 0.9rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 30px 0 15px 5px;
            text-align: left;
        }

        .task-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .btn-aufgabe {
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--text-main);
            text-decoration: none;
            padding: 20px;
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.2s;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .btn-aufgabe:hover {
            border-color: var(--thw-blue);
            transform: translateY(-2px);
            background: var(--bg-input);
        }

        /* Styling für erledigte Aufgaben */
        .btn-aufgabe.is-done {
            opacity: 0.6;
            background: rgba(16, 185, 129, 0.05);
            border-color: var(--success);
            pointer-events: none;
            cursor: default;
        }

        .task-name {
            font-weight: 600;
            font-size: 1.05rem;
            text-align: left;
            padding-right: 15px;
        }

        .done-badge {
            font-size: 0.75rem;
            color: var(--success);
            font-weight: 800;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 5px;
            margin-top: 4px;
        }

        .task-icon {
            width: 32px;
            height: 32px;
            background: rgba(37, 99, 235, 0.1);
            color: var(--thw-blue);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .btn-back {
            display: block;
            margin-top: 30px;
            padding: 15px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.9rem;
            text-align: center;
            border-radius: var(--radius);
            border: 1px dashed var(--border);
            transition: all 0.2s;
        }

        .btn-back:hover {
            color: var(--text-main);
            background: rgba(255,255,255,0.05);
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="participant-card">
            <div class="avatar-circle">
                <%= t.vorname.charAt(0) %><%= t.name.charAt(0) %>
            </div>
            <p class="participant-name"><%= t.vorname %> <%= t.name %></p>
            <div class="badge-info">
                <i class="fas fa-medal"></i> <%= t.abzeichen %>
            </div>
        </div>

        <h2>Verfügbare Aufgaben</h2>

        <div class="task-list">
            <% aufgaben.forEach(a => { %>
                <a href="/start-aufgabe/<%= a.id %>/<%= t.id %>/<%= station %>" 
                   class="btn-aufgabe <%= a.erledigt ? 'is-done' : '' %>">
                    
                    <div style="display: flex; flex-direction: column;">
                        <span class="task-name"><%= a.aufgabe_name %></span>
                        <% if (a.erledigt) { %>
                            <span class="done-badge"><i class="fas fa-check-double"></i> Bereits erledigt</span>
                        <% } %>
                    </div>

                    <div class="task-icon" style="<%= a.erledigt ? 'background: var(--success); color: white;' : '' %>">
                        <i class="fas <%= a.erledigt ? 'fa-check' : 'fa-chevron-right' %>"></i>
                    </div>
                </a>
            <% }) %>
        </div>

        <a href="/login" class="btn-back">
            <i class="fas fa-undo"></i> Abbrechen / Anderer Prüfling
        </a>
    </div>

</body>
</html>