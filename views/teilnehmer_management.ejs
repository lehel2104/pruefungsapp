<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teilnehmer Management | Leistungsabzeichen</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
              <link rel="icon" type="image/png" href="/pictures/Logo.png">
    <link rel="shortcut icon" href="/pictures/Logo.png" type="image/x-icon">
    <style>
        :root {
            --bg-deep: #0f172a;
            --bg-card: #1e293b;
            --bg-input: #334155;
            --thw-blue: #2563eb;
            --thw-yellow: #fbbf24;
            --success: #10b981;
            --danger: #ef4444;
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --border: #334155;
            --radius: 12px;
            --shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background-color: var(--bg-deep);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
            line-height: 1.5;
        }

        .container { max-width: 1200px; margin: 0 auto; }

        .back-link {
            display: inline-flex;
            align-items: center;
            text-decoration: none;
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 20px;
            transition: color 0.2s;
        }
        .back-link:hover { color: var(--thw-yellow); }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--bg-card);
            padding: 20px;
            border-radius: var(--radius);
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .stat-icon {
            width: 45px;
            height: 45px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .stat-card h4 { margin: 0; font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; }
        .stat-card p { margin: 5px 0 0 0; font-size: 1.5rem; font-weight: 800; }

        .main-card {
            background: var(--bg-card);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            overflow: hidden;
        }

        .card-header {
            padding: 20px 25px;
            background: rgba(255,255,255,0.02);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            flex-wrap: wrap;
            gap: 15px;
        }

        .card-header h1 { font-size: 1.25rem; margin: 0; color: var(--text-main); }

        /* Suchfeld Styling */
        .search-wrapper {
            position: relative;
            flex-grow: 1;
            max-width: 350px;
        }
        .search-wrapper i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
        }
        .search-input {
            width: 100%;
            padding: 10px 15px 10px 40px;
            background: var(--bg-deep);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text-main);
            outline: none;
            transition: all 0.2s;
        }
        .search-input:focus {
            border-color: var(--thw-blue);
            box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.2);
        }

        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        th {
            text-align: left;
            padding: 15px 25px;
            background: rgba(0,0,0,0.2);
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        td { padding: 15px 25px; border-bottom: 1px solid var(--border); vertical-align: middle; }
        tr:hover td { background: rgba(255,255,255,0.02); }
        tr.row-fertig td { background: rgba(16, 185, 129, 0.05); }

        .bubble-container { display: flex; gap: 6px; flex-wrap: wrap; }
        .bubble {
            width: 28px;
            height: 28px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.65rem;
            font-weight: 800;
            background: var(--bg-deep);
            color: var(--text-muted);
            border: 1px solid var(--border);
            transition: all 0.2s;
            cursor: pointer;
        }
        .bubble.done { 
            background: var(--success) !important; 
            color: white !important; 
            border-color: var(--success) !important; 
            box-shadow: 0 0 10px rgba(16, 185, 129, 0.2); 
        }
        .bubble.failed { 
            background: var(--danger) !important; 
            color: white !important; 
            border-color: var(--danger) !important; 
            box-shadow: 0 0 10px rgba(239, 68, 68, 0.4); 
        }
        .bubble.theory.active { 
            background: var(--thw-blue); 
            color: white; 
            border-color: var(--thw-blue); 
        }

        .progress-wrapper { width: 120px; }
        .progress-meta { display: flex; justify-content: space-between; font-size: 0.7rem; color: var(--text-muted); margin-top: 4px; }
        .progress-track { background: var(--bg-deep); height: 6px; border-radius: 10px; overflow: hidden; }
        .progress-fill { height: 100%; background: var(--thw-blue); border-radius: 10px; width: var(--w, 0%); transition: width 0.5s ease; }
        .row-fertig .progress-fill { background: var(--success); }

        .btn {
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            border: 1px solid var(--border);
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-danger { background: rgba(239, 68, 68, 0.1); color: var(--danger); border-color: rgba(239, 68, 68, 0.2); }
        .btn-danger:hover { background: var(--danger); color: white; }

        .badge {
            background: var(--bg-input);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.75rem;
            color: var(--thw-yellow);
            font-weight: 600;
        }

        .id-label { font-family: 'JetBrains Mono', monospace; color: var(--text-muted); font-size: 0.9rem; }

        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .modal-card {
            background: var(--bg-card);
            width: 90%;
            max-width: 500px;
            border-radius: var(--radius);
            border: 1px solid var(--border);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            overflow: hidden;
        }

        .modal-header {
            padding: 20px;
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h2 { margin: 0; font-size: 1.2rem; color: var(--thw-yellow); }

        .close-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 1.5rem;
            cursor: pointer;
        }

        .modal-body { padding: 20px; max-height: 70vh; overflow-y: auto; }

        .modal-task-item {
            padding: 15px;
            border-bottom: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .modal-task-item:last-child { border-bottom: none; }

        .task-status-badge {
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
        }

        .status-bestanden { background: rgba(16, 185, 129, 0.2); color: var(--success); }
        .status-nicht_bestanden { background: rgba(239, 68, 68, 0.2); color: var(--danger); }
        .status-offen { background: rgba(148, 163, 184, 0.1); color: var(--text-muted); }

    </style>
</head>
<body>

<div class="container">
    <a href="/" class="back-link">
        <i class="fas fa-arrow-left"></i> &nbsp; Prüfungs Dashboard
    </a>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(37, 99, 235, 0.1); color: var(--thw-blue);">
                <i class="fas fa-users"></i>
            </div>
            <div>
                <h4>Gesamt</h4>
                <p><%= teilnehmer.length %></p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(16, 185, 129, 0.1); color: var(--success);">
                <i class="fas fa-check-double"></i>
            </div>
            <div>
                <h4>Abgeschlossen</h4>
                <p><%= teilnehmer.filter(t => t.istFertig).length %></p>
            </div>
        </div>
    </div>

    <div class="main-card">
        <div class="card-header">
            <h1>Prüflinge</h1>
            
            <div class="search-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" id="searchInput" class="search-input" placeholder="Name oder ID suchen...">
            </div>

          
<a href="/admin/drucken-status-view" target="_blank" class="btn btn-blue" style="background: #172643;">
    <i class="fas fa-print"></i> Alle Drucken (Live-Status)
</a>

            <div style="display: flex; gap: 10px;">
                <a href="/admin/export-alle-pdfs" class="btn" style="background: rgba(16, 185, 129, 0.1); color: var(--success); border-color: rgba(16, 185, 129, 0.2);">
                    <i class="fas fa-file-archive"></i> Alle PDFs (ZIP)
                </a>

                <form action="/admin/reset-pruefung" method="POST" onsubmit="return confirm('ACHTUNG: Alle Prüfungsdaten unwiderruflich löschen?')">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash-alt"></i> Löschen
                    </button>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>OV</th>
                        <th>Abzeichen</th>
                        <th>Status-Knoten</th>
                        <th>Fortschritt</th>
                        <th style="text-align: right;">Verwaltung</th>
                    </tr>
                </thead>
                <tbody id="participantTable">
                    <% teilnehmer.forEach(t => { %>
                    <tr class="<%= t.istFertig ? 'row-fertig' : '' %>">
                        <td><span class="id-label">#<%= t.id %></span></td>
                        
                        <td class="name-cell">
                            <div style="font-weight: 700; color: var(--text-main);"><%= t.vorname %> <%= t.name %></div>
                                                
                                               <td class="ov-cell">
                            <div style="font-weight: 700; color: var(--text-main);"><%= t.ov %></div> 
                                                
                                                
                            <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px;">
                                Praxis: <span style="color: <%= t.anzahlBestanden >= t.mindestSoll ? 'var(--success)' : 'var(--danger)' %>">
                                    <%= t.anzahlBestanden %> von <%= t.mindestSoll %>
                                </span>
                            </div>

                            <% if (t.istFertig) { %>
                                <div style="margin-top: 5px;">
                                    <% if (t.gesamtBestanden) { %>
                                        <span class="badge" style="background: rgba(16, 185, 129, 0.2); color: var(--success); border: 1px solid var(--success);">
                                            <i class="fas fa-medal"></i> BESTANDEN
                                        </span>
                                    <% } else { %>
                                        <span class="badge" style="background: rgba(239, 68, 68, 0.2); color: var(--danger); border: 1px solid var(--danger);">
                                            <i class="fas fa-times-circle"></i> n. best.
                                        </span>
                                    <% } %>
                                </div>
                            <% } %>
                        </td>

                        <td><span class="badge"><%= t.abzeichen %></span></td>

                        <td>
                            <div class="bubble-container">
                                <% 
                                    let thClass = "";
                                    if (t.hatTheorie) {
                                        thClass = (t.theorieBestanden) ? "theory active" : "failed";
                                    }

                                    let thObj = [{ 
                                        name: 'Theorie-Test', 
                                        status: t.theorieBestanden ? 'bestanden' : (t.hatTheorie ? 'nicht_bestanden' : 'offen'), 
                                        fehler: t.anzahlTheoriePunkte || 0,
                                        liste: t.theorieDetails 
                                    }];
                                    let b64Th = Buffer.from(JSON.stringify(thObj)).toString('base64');
                                %>
                                <div class="bubble <%= thClass %>" 
                                     title="Theorie" 
                                     onclick="showStationDetails('Theorie', '<%= b64Th %>')">
                                    T
                                </div>

                                <% (t.stationenDetails || []).forEach(s => { %>
                                    <% 
                                        let sClass = s.erledigt ? (s.ergebnis === 'nicht_bestanden' ? 'failed' : 'done') : '';
                                        let b64S = Buffer.from(JSON.stringify(s.details || [])).toString('base64');
                                    %>
                                    <div class="bubble <%= sClass %>" 
                                         onclick="showStationDetails('Station <%= s.nummer %>', '<%= b64S %>')">
                                        S<%= s.nummer %>
                                    </div>
                                <% }) %>
                            </div>
                        </td>

                        <td>
                            <% let prozent = (t.gesamtSoll > 0) ? Math.round((t.fortschritt / t.gesamtSoll) * 100) : 0; %>
                            <div class="progress-wrapper">
                                <div class="progress-track">
                                    <div class="progress-fill" style="--w: <%= prozent %>%"></div>
                                </div>
                                <div class="progress-meta">
                                    <span><%= prozent %>%</span>
                                    <span><%= t.fortschritt %> / <%= t.gesamtSoll %></span>
                                </div>
                            </div>
                        </td>
                        <td style="text-align: right;">
                            <a href="/admin/export-pdf/<%= t.id %>" class="btn" style="background: rgba(251, 191, 36, 0.1); color: var(--thw-yellow); border-color: rgba(251, 191, 36, 0.2);" title="PDF Export">
                                <i class="fas fa-file-pdf"></i>
                            </a>
                            <a href="/admin/delete-teilnehmer/<%= t.id %>" class="btn btn-danger" onclick="return confirm('Teilnehmer löschen?')">
                                <i class="fas fa-user-minus"></i>
                            </a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="stationModal" class="modal-overlay" onclick="closeModal()">
    <div class="modal-card" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2 id="modalTitle">Station Details</h2>
            <button class="close-btn" onclick="closeModal()">&times;</button>
        </div>
        <div id="modalBody" class="modal-body"></div>
    </div>
</div>

<script>
// --- LIVE SUCHE FUNKTION ---
document.getElementById('searchInput').addEventListener('keyup', function() {
    const filter = this.value.toLowerCase();
    const rows = document.querySelectorAll('#participantTable tr');

    rows.forEach(row => {
        const text = row.innerText.toLowerCase();
        if (text.includes(filter)) {
            row.style.display = "";
        } else {
            row.style.display = "none";
        }
    });
});

function showStationDetails(title, b64Data) {
    let details;
    try {
        details = JSON.parse(atob(b64Data));
    } catch (e) {
        console.error("Fehler beim Laden der Details:", e);
        return alert("Fehler beim Laden der Daten.");
    }

    const modal = document.getElementById('stationModal');
    const modalTitle = document.getElementById('modalTitle');
    const modalBody = document.getElementById('modalBody');

    modalTitle.innerText = title;
    modalBody.innerHTML = ''; 

    if (!details || details.length === 0) {
        modalBody.innerHTML = '<p style="color: var(--text-muted); padding: 20px;">Keine Aufgaben gefunden.</p>';
    } else {
        details.forEach(task => {
            const statusClass = `status-${task.status}`;
            const statusText = task.status === 'bestanden' ? 'Bestanden' : (task.status === 'nicht_bestanden' ? 'nicht bestanden' : 'Offen');
            const unit = title.includes('Theorie') ? 'Punkte' : 'Fehler';
            const showValue = task.status !== 'offen';

            let fragenHtml = '';
            if (task.liste) {
                try {
                    const listeObj = typeof task.liste === 'string' ? JSON.parse(task.liste) : task.liste;
                    if (Array.isArray(listeObj) && listeObj.length > 0) {
                        fragenHtml = `
                            <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 5px; width: 100%; margin-top: 12px; padding-top: 12px; border-top: 1px dashed var(--border);">
                                ${listeObj.map(f => `
                                    <div style="font-size: 0.7rem; padding: 4px; border-radius: 4px; text-align: center; font-weight: bold;
                                        background: ${f.r ? 'rgba(16,185,129,0.15)' : 'rgba(239,68,68,0.15)'}; 
                                        color: ${f.r ? 'var(--success)' : 'var(--danger)'}; 
                                        border: 1px solid ${f.r ? 'var(--success)' : 'var(--danger)'}">
                                        Q${f.n}<br>${f.r ? '✔' : '✘'}
                                    </div>
                                `).join('')}
                            </div>`;
                    }
                } catch (e) { console.error("Parse Fehler Listen:", e); }
            }

            modalBody.innerHTML += `
                <div class="modal-task-item">
                    <div style="display: flex; justify-content: space-between; width: 100%; align-items: center;">
                        <div class="task-info">
                            <div style="font-weight: 600; font-size: 0.95rem;">${task.name}</div>
                            ${showValue ? `<div style="color: var(--text-muted); font-size: 0.8rem; margin-top: 4px;">Ergebnis: <b style="color: var(--text-main)">${task.fehler}</b> ${unit}</div>` : ''}
                        </div>
                        <span class="task-status-badge ${statusClass}">${statusText}</span>
                    </div>
                    ${fragenHtml}
                </div>
            `;
        });
    }

    modal.style.display = 'flex';
}

function closeModal() {
    document.getElementById('stationModal').style.display = 'none';
}

document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
});
</script>
</body>
</html>